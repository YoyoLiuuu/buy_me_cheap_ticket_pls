generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SavedSearch {
  id             String   @id @default(cuid())
  legs           Json
  filters        Json
  flexibility    Int      @default(0)
  email          String
  token          String   @unique @default(cuid())
  active         Boolean  @default(true)
  alertThreshold Int      @default(10)
  digestEnabled  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  priceRecords PriceRecord[]
  alertLogs    AlertLog[]

  @@index([email])
  @@index([active])
}

model PriceRecord {
  id            String      @id @default(cuid())
  searchId      String
  search        SavedSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  checkedAt     DateTime    @default(now())
  cheapestPrice Float
  currency      String      @default("CAD")
  topResults    Json

  @@index([searchId, checkedAt])
}

model AlertLog {
  id       String      @id @default(cuid())
  searchId String
  search   SavedSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  sentAt   DateTime    @default(now())
  type     String
  price    Float

  @@index([searchId, sentAt])
}
